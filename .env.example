# ─────────────────────────────────────────────────────────────────────────────
# Final Whistle Rooms — environment configuration
# Copy to `.env.local`. Every value has a safe default; the app runs with none.
# ─────────────────────────────────────────────────────────────────────────────

# Data source mode:
#   "simulation" (default) — deterministic on-device replay of TxLINE-shaped feeds.
#                            Always works, no credentials, ideal for judges + demo.
#   "live"                 — proxy the real TxLINE API (requires the vars below).
TXLINE_MODE=simulation

# ── Live mode only (TXLINE_MODE=live) ────────────────────────────────────────
# Easiest: run `pnpm txline:activate` (see TXLINE_LIVE.md) — it mints a real
# token and writes TXLINE_MODE/TXLINE_BASE_URL/TXLINE_API_TOKEN/competition id
# into .env.local for you.
#
# TxLINE host: txline.txodds.com (mainnet) / txline-dev.txodds.com (devnet).
TXLINE_BASE_URL=https://txline.txodds.com
# Long-lived API token from activation (the mint script writes this).
TXLINE_API_TOKEN=
# World Cup competition id (auto-discovered by the mint script; optional filter).
TXLINE_COMPETITION_ID=
# Alternative to a pasted token: a funded host keypair + confirmed subscribe
# txSig, to run activation server-side. Used ONLY server-side.
TXLINE_HOST_SECRET_KEY=
TXLINE_TX_SIG=

# ── Solana ───────────────────────────────────────────────────────────────────
# Cluster used for the optional on-chain proof anchor + identity.
NEXT_PUBLIC_SOLANA_CLUSTER=devnet
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com
# If set, room proof Merkle roots are anchored on-chain via a memo tx from this
# host keypair (base58 secret key). Optional — proofs verify locally without it.
SOLANA_ANCHOR_SECRET_KEY=

# ── AI recap ─────────────────────────────────────────────────────────────────
# Optional. If set, halftime/full-time recaps are generated by Claude.
# If unset, a high-quality deterministic local generator is used (fully offline).
ANTHROPIC_API_KEY=
ANTHROPIC_RECAP_MODEL=claude-haiku-4-5-20251001

# ── Demo pacing ──────────────────────────────────────────────────────────────
# Real seconds per simulated match minute. Lower = faster demo.
# 2 => a 90' match plays out in ~3 minutes.
SIM_SECONDS_PER_MATCH_MINUTE=2
